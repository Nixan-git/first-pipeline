cat > .gitignore <<'EOF'
# Exclude local-only remote state project
1-remotestate/

# Terraform
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.*
**/crash.log
**/crash.*.log

# Sensitive / local overrides
**/*.tfvars
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json

# Optional: plans
**/*.tfplan

# OS
.DS_Store
Thumbs.db
EOF